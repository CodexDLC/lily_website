# =============================================================
# lily_backend — Environment Variables
# Copy to .env and fill in values before running.
# =============================================================

# --- General ---
DEBUG=False
SECRET_KEY=KJeMtZ2BVRHlJ6YbDjZPfHxJCQTphC3jJT1pFeJ40XFTVWwv4w7ldANnNqmF0J956jc
DOMAIN_NAME=
ALLOWED_HOSTS=,www.
SITE_BASE_URL=https:///
CSRF_COOKIE_NAME=csrftoken_app
# Leave unset for a single canonical host (recommended for lily-salon.de).
CSRF_COOKIE_DOMAIN=
SESSION_COOKIE_DOMAIN=

DJANGO_SETTINGS_MODULE=lily_backend.core.settings.prod

# --- Database ---
DATABASE_URL=postgresql://lily_user:change_me_postgres_password@db:5432/lily_db # pragma: allowlist secret
LEGACY_DATABASE_URL=postgresql://user:password@legacy-neon-host/dbname # pragma: allowlist secret
BACKUP_NEON_DATABASE_URL=postgresql://user:password@warm-neon-host/dbname # pragma: allowlist secret
ENABLE_NEON_WARM_SYNC=False
POSTGRES_DB=lily_db
POSTGRES_USER=lily_user
POSTGRES_PASSWORD=change_me_postgres_password
BACKUP_DIR=/opt/lily_website/backups
RETENTION_DAYS=14

# --- Encrypted Postgres backups in Hetzner Object Storage ---
BACKUP_S3_ENABLED=False
BACKUP_S3_BUCKET=lily-postgres-backups
BACKUP_S3_ENDPOINT=https://nbg1.your-objectstorage.com
BACKUP_S3_REGION=nbg1
BACKUP_S3_PREFIX=postgres
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_ENCRYPTION_PASSWORD=
BACKUP_AWS_CLI_IMAGE=public.ecr.aws/aws-cli/aws-cli:latest
BACKUP_HEALTHCHECK_URL=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
USE_CODEX_REDIS_BACKENDS=False

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=noreply@
SMTP_USE_TLS=False

EMAIL_HOST=${SMTP_HOST}
EMAIL_PORT=${SMTP_PORT}
EMAIL_HOST_USER=${SMTP_USER}
EMAIL_HOST_PASSWORD=${SMTP_PASSWORD}
DEFAULT_FROM_EMAIL=${SMTP_FROM_EMAIL}
EMAIL_USE_TLS=${SMTP_USE_TLS}



# --- Gunicorn ---
GUNICORN_WORKERS=2

# --- Logging ---
LOG_LEVEL=INFO

# --- Docker Images (prod) ---
DOCKER_IMAGE_BACKEND=ghcr.io/your-org/lily_backend-backend:latest
DOCKER_IMAGE_WORKER=ghcr.io/your-org/lily_backend-worker:latest
DOCKER_IMAGE_NGINX=ghcr.io/your-org/lily_backend-nginx:latest
