# ═══════════════════════════════════════════
# lily_website — Unified Environment Variables
# ═══════════════════════════════════════════

# === 1. GENERAL SETTINGS ===
# DEBUG: True (development), False (production)
DEBUG=True
DOMAIN_NAME=lily-salon.de
# DJANGO_SETTINGS_MODULE: core.settings.dev, core.settings.prod
DJANGO_SETTINGS_MODULE=core.settings.dev
# Generate a secure key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1,lily-salon.de
# SITE_BASE_URL: https://lily-salon.de/ (Must include protocol and trailing slash)
SITE_BASE_URL=http://localhost:8000/

# === 2. DATABASE SETTINGS (Django) ===
# For Production/Neon use DATABASE_URL. For local use individual fields or leave empty for SQLite.
DATABASE_URL=
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# === 3. REDIS SETTINGS ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === 4. TELEGRAM BOT SETTINGS ===
BOT_TOKEN=your_bot_token_here
SUPERUSER_IDS=
OWNER_IDS=
BOT_DATA_MODE=api
BACKEND_API_URL=http://backend:8000

# API Keys for Bot <-> Backend communication
BOT_API_KEY=
BACKEND_API_KEY=

# Telegram Channel & Topics (for notifications routing)
TELEGRAM_ADMIN_CHANNEL_ID=-1003363984639
TELEGRAM_NOTIFICATION_TOPIC_ID=1
TELEGRAM_TOPICS={"hair": 2, "nails": 4, "face": 6, "eyes": 8, "body": 10, "depilation": 12}


# === 5. EXTERNAL SERVICES (Twilio) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SEVEN_IO_API_KEY=
SENDGRID_API_KEY=


# === 6. EMAIL SETTINGS ===
# Django SMTP transport (used by Django + notification worker).
# Identity (From/sender name/reply-to) lives in SiteSettings / cabinet UI,
# credentials live here only — never in the database.
EMAIL_HOST=mail.spacemail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@lily-salon.de

# Legacy aliases consumed by the notification worker (src/workers). Keep in
# sync with EMAIL_* above until workers are refactored to read EMAIL_*
# directly.
SMTP_HOST=${EMAIL_HOST}
SMTP_PORT=${EMAIL_PORT}
SMTP_USER=${EMAIL_HOST_USER}
SMTP_PASSWORD=${EMAIL_HOST_PASSWORD}
SMTP_FROM_EMAIL=${DEFAULT_FROM_EMAIL}
SMTP_USE_TLS=${EMAIL_USE_TLS}

# Inbound email import (optional). Leave empty for local Mailpit-only setups.
# Mailpit in deploy/docker-compose.yml exposes SMTP/HTTP, not IMAP.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# === 7. MONITORING (Grafana Cloud) ===
GCLOUD_HOSTED_METRICS_URL=
GCLOUD_HOSTED_METRICS_ID=
GCLOUD_HOSTED_LOGS_URL=
GCLOUD_HOSTED_LOGS_ID=
GCLOUD_RW_API_KEY=

# === 8. LOGGING ===
LOG_LEVEL=DEBUG
